{
  "version": "1.0",
  "run_name": "webbgpt-local-mvp-sft0-plumbing",
  "seed": 52,
  "global_batch_size": 1,
  "micro_batch_size": 1,
  "gradient_accumulation_steps": 1,
  "learning_rate": 0.00003,
  "min_learning_rate": 0.000003,
  "warmup_steps": 1,
  "max_steps": 20,
