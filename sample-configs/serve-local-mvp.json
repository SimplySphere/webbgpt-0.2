{
  "version": "1.0",
  "host": "0.0.0.0",
  "port": 8000,
  "model_name": "webbgpt-local-mvp",
  "model_mode": "pretrained",
  "seed": 52,
  "checkpoint_path": "artifacts/runs/local-mvp/checkpoints/pretrain/best-pretrain",
  "tokenizer_path": "artifacts/tokenizer/webbgpt-local-mvp.model",
  "model_config_path": "sample-configs/model-local-mvp.json",
  "max_model_len": 512,
  "tensor_parallel_size": 1,
  "trust_remote_code": false,
  "grounding": null,
  "enable_grounding": false,
  "enable_citations": false,
  "decode_preset": "local-mvp-serve",
  "max_new_tokens": 48,
  "temperature": 0.3,
  "top_k": 30,
  "top_p": 0.92,
  "repetition_penalty": 1.15,
  "no_repeat_ngram_size": 4,
  "stop_strings": [
    "</s>",
    "<|assistant|>",
    "<|user|>",
    "<|system|>",
    "<|tool|>",
    "<|citation|>"
  ],
  "use_rag": false,
  "rag_index_path": "data/rag/webbgpt_index.json",
  "rag_chunks_path": "data/rag/webbgpt_chunks.jsonl",
  "rag_top_k": 3,
  "rag_min_score": 0.05,
  "rag_min_lexical_overlap": 0.45,
  "rag_min_matched_terms": 2,
  "rag_require_named_terms": true,
  "rag_min_top_score_margin": 0.0,
  "transcript_path": "artifacts/runs/local-mvp/manual_demos/chat_transcript.jsonl"
}
