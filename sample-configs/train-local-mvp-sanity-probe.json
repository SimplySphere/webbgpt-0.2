{
  "version": "1.0",
  "run_name": "webbgpt-local-mvp-sanity-probe",
  "seed": 52,
  "global_batch_size": 4,
  "micro_batch_size": 1,
  "gradient_accumulation_steps": 4,
  "learning_rate": 0.0005,
  "min_learning_rate": 5e-05,
  "warmup_steps": 20,
  "max_steps": 100,
  "token_budget": null,
  "pretrain_progress_mode": "steps",
  "pretrain_stop_mode": "max_steps_limited",
  "pretrain_flush_final_partial_accumulation": true,
  "eval_every_steps": 25,
  "num_eval_batches": 8,
  "final_eval_full_validation": false,
  "final_num_eval_batches": 8,
  "compile_model": false,
  "use_bf16": false,
  "log_every_steps": 5,
  "pretrain_probe_path": "data/eval/pretrain_general_regression.jsonl",
  "pretrain_family_holdouts_path": "data/eval/pretrain_family_holdouts_general.json",
  "log_batch_provenance_extremes": true,
  "severe_low_loss_threshold": 0.05,
  "suspicious_low_loss_threshold": 0.1,
  "broad_low_loss_threshold": 0.5,
  "low_loss_probe_threshold": 0.5,
  "high_loss_probe_threshold": null,
  "posttrain_top_k_checkpoints": 2,
  "checkpoint": {
    "output_dir": "artifacts/runs/local-mvp/checkpoints/sanity-probe",
    "save_every_steps": 25,
    "keep_last_n": 2,
    "async_write": false,
    "initialize_from": null,
    "resume_from": null,
    "export_every_eval": false
  },
  "report_to": [
    "stdout"
  ]
}
