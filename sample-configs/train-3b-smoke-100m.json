{
  "version": "1.0",
  "run_name": "webbgpt-3b-smoke-100m",
  "seed": 52,
  "global_batch_size": 64,
  "micro_batch_size": 1,
  "gradient_accumulation_steps": 8,
  "learning_rate": 0.0002,
  "min_learning_rate": 0.00002,
  "warmup_steps": 50,
  "max_steps": 250,
  "token_budget": 100000000,
  "pretrain_progress_mode": "token_budget",
  "pretrain_stop_mode": "one_prepared_pass",
  "pretrain_flush_final_partial_accumulation": true,
  "eval_every_steps": 50,
  "num_eval_batches": 16,
  "final_eval_full_validation": true,
  "final_num_eval_batches": null,
  "pretrain_probe_path": "data/eval/pretrain_general_regression.jsonl",
  "pretrain_family_holdouts_path": "data/eval/pretrain_family_holdouts_general.json",
  "log_batch_provenance_extremes": true,
  "severe_low_loss_threshold": 0.05,
  "suspicious_low_loss_threshold": 0.1,
  "broad_low_loss_threshold": 0.5,
  "low_loss_probe_threshold": 0.5,
  "compile_model": true,
  "use_bf16": true,
  "activation_checkpointing": true,
  "fsdp_sharding_strategy": "full_shard",
  "max_grad_norm": 1.0,
  "weight_decay": 0.1,
  "adam_beta1": 0.9,
  "adam_beta2": 0.95,
  "adam_eps": 1e-08,
  "log_every_steps": 10,
  "report_to": [
    "stdout"
  ],
  "checkpoint": {
    "output_dir": "artifacts/runs/scale-3b-smoke-100m/checkpoints/pretrain",
    "save_every_steps": 100,
    "keep_last_n": 3,
    "async_write": false,
    "initialize_from": null,
    "resume_from": null,
    "export_every_eval": false
  }
}
