{
  "version": "1.0",
  "run_name": "webbgpt-local-mvp-continue-small",
  "seed": 52,
  "global_batch_size": 8,
  "micro_batch_size": 2,
  "gradient_accumulation_steps": 4,
  "learning_rate": 5e-05,
  "min_learning_rate": 5e-06,
  "warmup_steps": 10,
  "max_steps": 100,
  "continued_learning_rate": 5e-05,
  "continued_min_learning_rate": 5e-06,
  "continued_warmup_steps": 10,
  "continued_max_steps": 100,
  "token_budget": 300000,
  "pretrain_progress_mode": "prepared_tokens",
  "pretrain_stop_mode": "one_prepared_pass",
  "pretrain_flush_final_partial_accumulation": true,
  "eval_every_steps": 25,
  "num_eval_batches": 8,
  "final_eval_full_validation": true,
  "final_num_eval_batches": 16,
  "compile_model": false,
  "use_bf16": false,
  "activation_checkpointing": false,
  "fsdp_sharding_strategy": "full_shard",
  "max_grad_norm": 1.0,
  "weight_decay": 0.05,
  "adam_beta1": 0.9,
  "adam_beta2": 0.95,
  "adam_eps": 1e-08,
  "log_every_steps": 10,
  "pretrain_probe_path": "data/eval/pretrain_general_regression.jsonl",
  "pretrain_family_holdouts_path": "data/eval/pretrain_family_holdouts_general.json",
  "log_batch_provenance_extremes": true,
  "report_to": [
    "stdout"
  ],
  "checkpoint": {
    "output_dir": "artifacts/runs/local-mvp/checkpoints/continue-small",
    "save_every_steps": 25,
    "keep_last_n": 3,
    "async_write": false,
    "initialize_from": "artifacts/runs/local-mvp/checkpoints/pretrain/best-pretrain",
    "resume_from": null,
    "export_every_eval": false
  }
}
